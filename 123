🧹 第九步：清理资源（避免费用）

```bash
# 1. 删除 S3 数据
aws s3 rm s3://${S3_BUCKET} --recursive
aws s3 rb s3://${S3_BUCKET}

# 2. 删除 Glue 元数据
aws glue delete-table --database-name ${GLUE_DB} --name consumer_sales
aws glue delete-table --database-name ${GLUE_DB} --name commercial_sales
aws glue delete-database --name ${GLUE_DB}

# 3. 删除 LF-Tag（会同时解除所有分配）
aws lakeformation delete-lf-tag --tag-key division
aws lakeformation delete-lf-tag --tag-key confidentiality

# 4. 删除 IAM 角色
for role in DataAdmin ConsumerAnalyst CommercialAnalyst PublicDataAnalyst MaskedAnalyst; do
  # 先分离策略
  aws iam detach-role-policy --role-name $role --policy-arn arn:aws:iam::aws:policy/AmazonAthenaFullAccess
  aws iam detach-role-policy --role-name $role --policy-arn arn:aws:iam::aws:policy/service-role/AWSGlueServiceRole
  aws iam delete-role-policy --role-name $role --policy-name S3Access
  aws iam delete-role --role-name $role
done

# 5. 删除本地临时文件
rm -f trust-policy.json s3-access-policy.json consumer_sales.csv commercial_sales.csv lakeformation-iam-policy.json
```

